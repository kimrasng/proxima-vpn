# ===========================================
# Solix VPN Panel - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# cp .env.example .env

# Required - API server will not start without these
JWT_SECRET=change-me-to-a-random-64-char-string

# Database
POSTGRES_USER=vpnuser
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vpnpanel
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Panel
PANEL_URL=http://your-server-ip:8080

# Admin (used only on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# Backup S3 (optional)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# --- Feature Flags ---
# Set to false in production to disable Swagger UI
SWAGGER_ENABLED=true
